# ============================================================
# BACKEND — copy to backend/.env
# ============================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key       # never expose this to frontend
SUPABASE_ANON_KEY=your-anon-key

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173               # change for production

# Crypto — Platform hot wallet (used to send withdrawals)
PLATFORM_WALLET_ADDRESS=0xYourPlatformWalletAddress
PLATFORM_WALLET_PRIVATE_KEY=0xYourPrivateKey    # KEEP SECRET, never commit

# RPC endpoints (free tier: infura.io / alchemy.com / publicnode.com)
POLYGON_RPC_URL=https://polygon-rpc.com
ETH_RPC_URL=https://eth.llamarpc.com


# ============================================================
# FRONTEND — copy to frontend/.env
# ============================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

VITE_API_URL=http://localhost:3001/api           # change for production
VITE_SOCKET_URL=http://localhost:3001            # change for production

VITE_PLATFORM_WALLET_ADDRESS=0xYourPlatformWalletAddress   # shown on deposit page

# Set to "true" to use Polygon Mumbai testnet, "false" for mainnet
VITE_USE_TESTNET=true
